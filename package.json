{
  "name": "dispatch-mcp",
  "version": "1.0.0",
  "description": "Multi-agent orchestrator MCP — describe the job, Dispatch figures out who handles it.",
  "type": "module",
  "engines": {
    "node": ">=18"
  },
  "files": ["dist", "src/banner.txt"],
  "bin": {
    "dispatch-mcp": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "scripts": {
    "build": "tsc",
    "dev": "NODE_OPTIONS='--no-deprecation' tsx src/index.ts",
    "start": "node --no-deprecation dist/index.js",
    "test": "npm run build && node --no-deprecation --test test/planner.test.js"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/AlexisLspk/dispatch-mcp.git"
  },
  "bugs": {
    "url": "https://github.com/AlexisLspk/dispatch-mcp/issues"
  },
  "homepage": "https://github.com/AlexisLspk/dispatch-mcp#readme",
  "keywords": ["mcp", "ai", "agents", "orchestrator", "cursor", "claude"],
  "license": "MIT",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@modelcontextprotocol/sdk": "^1.0.0",
    "dotenv": "^16.4.5",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  }
}
